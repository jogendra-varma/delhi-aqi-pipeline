    "from pyspark.sql.functions import round as spark_round\n",
    "\n",
    "def calculate_aqi_pm25(pm25):\n",
    "    # CPCB Breakpoints for PM2.5\n",
    "    # (C_low, C_high, AQI_low, AQI_high)\n",
    "    breakpoints = [\n",
    "        (0,    30,   0,   50),\n",
    "        (30,   60,   51,  100),\n",
    "        (60,   90,   101, 200),\n",
    "        (90,   120,  201, 300),\n",
    "        (120,  250,  301, 400),\n",
    "        (250,  500,  401, 500),\n",
    "    ]\n",
    "    \n",
    "    result = None\n",
    "    for c_low, c_high, aqi_low, aqi_high in breakpoints:\n",
    "        if c_low <= pm25 <= c_high:\n",
    "            result = ((aqi_high - aqi_low) / \n",
    "                     (c_high - c_low)) * \\\n",
    "                     (pm25 - c_low) + aqi_low\n",
    "            break\n",
    "    return float(result) if result else 500.0\n",
    "\n",
    "# Register as Spark UDF\n",
    "from pyspark.sql.types import FloatType\n",
    "from pyspark.sql.functions import udf\n",
    "\n",
    "aqi_udf = udf(calculate_aqi_pm25, FloatType())\n",
    "\n",
    "# Apply to dataframe\n",
    "silver_df = silver_df.withColumn(\n",
    "    \"aqi_calculated\", \n",
    "    spark_round(aqi_udf(col(\"pm25\")), 1)\n",
    ").withColumn(\n",
    "    \"aqi_bucket_calculated\",\n",
    "    when(col(\"aqi_calculated\") <= 50,  \"Good\")\n",
    "    .when(col(\"aqi_calculated\") <= 100, \"Satisfactory\")\n",
    "    .when(col(\"aqi_calculated\") <= 200, \"Moderate\")\n",
    "    .when(col(\"aqi_calculated\") <= 300, \"Poor\")\n",
    "    .when(col(\"aqi_calculated\") <= 400, \"Very Poor\")\n",
    "    .otherwise(\"Severe\")\n",
    ")\n",
    "\n",
    "# Compare original vs calculated\n",
    "silver_df.select(\n",
    "    \"date\", \"pm25\", \n",
    "    \"aqi_original\", \n",
    "    \"aqi_calculated\",\n",
    "    \"aqi_bucket_calculated\"\n",
    ").show(10)"
